# ---- MCPGuard backend configuration ----
# Copy to .env and fill in. NEVER commit a real .env.

# Environment: development | production | test
ENV=development

# REQUIRED in production. Generate with: openssl rand -base64 48
# In development an ephemeral key is auto-generated if left blank.
JWT_SECRET=
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database. SQLite default is zero-config for local dev.
# Production Postgres example:
# DATABASE_URL=postgresql+asyncpg://mcpguard:password@db:5432/mcpguard
DATABASE_URL=sqlite+aiosqlite:///./mcpguard.db

# Redis for distributed rate limiting (recommended in production).
# REDIS_URL=redis://redis:6379/0

# Rate limiting.
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# CORS allowed origins (comma-separated). No wildcard with credentials.
CORS_ORIGINS=http://localhost:3000

# Alert webhook (Slack-compatible JSON POST). Leave unset for simulation mode:
# high/critical alerts are logged instead of sent.
# Must be HTTPS and must not resolve to a private address (SSRF guard).
# ALERT_WEBHOOK_URL=https://hooks.example.com/services/XXX
ALERT_WEBHOOK_MIN_SEVERITY=high

# Behavioral anomaly thresholds (R6 rapid-fire, R7 probing, R8 enumeration).
# Windows in seconds. Tune per deployment.
ANOMALY_RAPID_FIRE_WINDOW_S=60
ANOMALY_RAPID_FIRE_THRESHOLD=30
ANOMALY_BLOCKED_WINDOW_S=600
ANOMALY_BLOCKED_THRESHOLD=3
ANOMALY_ENUM_WINDOW_S=300
ANOMALY_ENUM_DISTINCT_TOOLS=10
ANOMALY_DEDUPE_WINDOW_S=600

# Statistical baseline (R10): per-agent learned volume anomaly.
BASELINE_BUCKET_SECONDS=3600
BASELINE_WINDOW_BUCKETS=168
BASELINE_MIN_OBSERVATIONS=5
BASELINE_Z_THRESHOLD=3.0

# Tool-sequence baseline (R11): per-agent tool-transition anomaly.
SEQUENCE_WINDOW_SECONDS=604800
SEQUENCE_MIN_TRANSITIONS=20
SEQUENCE_RARE_PROB=0.02

# Data-volume baseline (R12): per-agent payload-byte volume anomaly.
DATAVOL_BUCKET_SECONDS=3600
DATAVOL_WINDOW_BUCKETS=168
DATAVOL_MIN_OBSERVATIONS=5
DATAVOL_Z_THRESHOLD=3.0
DATAVOL_MIN_BYTES=10000

# Cross-agent correlation (R13): coordinated multi-agent campaign detection.
CORRELATION_WINDOW_SECONDS=300
CORRELATION_MIN_AGENTS=8
CORRELATION_MIN_BLOCKED_AGENTS=3

# Incident case management: window in which new alerts join an open incident
# for the same subject (server + agent) instead of opening a fresh case.
INCIDENT_WINDOW_SECONDS=3600

# Response-time SLAs (seconds to first acknowledgement), by severity. A case
# breaches if still 'open' past its target. Tighter for worse severities.
SLA_CRITICAL_SECONDS=900
SLA_HIGH_SECONDS=3600
SLA_MEDIUM_SECONDS=14400
SLA_LOW_SECONDS=86400
# Dev-only escape hatches for the SSRF guard. NEVER enable in production.
# ALERT_WEBHOOK_ALLOW_INSECURE=true
# ALERT_WEBHOOK_ALLOW_PRIVATE=true

# Bootstrap admin, seeded only on first run when no users exist.
# CHANGE THESE. The password must be rotated immediately after first login.
FIRST_ADMIN_EMAIL=admin@mcpguard.local
FIRST_ADMIN_PASSWORD=ChangeMe!Admin123
